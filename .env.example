# Pythia backend configuration.
#
#   cp .env.example .env      then fill in your own values
#
# `.env` is gitignored — it never gets committed. The desktop app does NOT use
# this file; it stores keys in the OS keychain (Settings → Alpaca / AI providers).
# NEVER paste real keys into .env.example, screenshots, or chat.

# ── server ───────────────────────────────────────────────────────────────────
PYTHIA_BIND=127.0.0.1:8787
# Optional Discord/webhook URL for fills, exits and risk trips
# PYTHIA_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Alpaca (real equity quotes + live execution) ──────────────────────────────
# Paper keys from https://app.alpaca.markets → API. Paper and live accounts have
# SEPARATE keys — paper keys only work against the paper endpoint, which is what
# the Live page selects by default. Trade permission is enough; no withdrawal.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
# Market-data feed: iex = free tier (default), sip = paid subscription
APCA_FEED=iex

# ── AI signal providers (all optional — set only what you use) ────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# ZAI_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# MISTRAL_API_KEY=
